{
  "app": {
    "name": "seju-lite",
    "env": "dev",
    "logLevel": "INFO"
  },
  "agent": {
    "name": "SejuLite",
    "systemPrompt": "", 
    "maxIterations": 8,
    "maxHistory": 12,
    "workspace": "./workspace",
    "enableMemory": true,
    "enableSkills": true,
    "enableTools": true
  },
  "provider": {
    "kind": "gemini",
    "apiKey": "${GEMINI_API_KEY}",
    "model": "gemini-2.5-flash-lite",
    "temperature": 0.3,
    "maxOutputTokens": 1200
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["baekseju2901"],
      "allowGroups": false,
      "groupPolicy": "mention"
    }
  },
  "tools": {
    "time": {
      "enabled": true
    },
    "readFile": {
      "enabled": true,
      "rootDir": "./workspace"
    },
    "shell": {
      "enabled": false,
      "allowedCommands": ["pwd", "ls", "cat"],
      "timeoutSec": 8
    },
    "web": {
      "enabled": true,
      "maxChars": 12000
    }
  },
  "storage": {
    "sessionFile": "./workspace/sessions.json"
  }
}
